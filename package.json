{
  "name": "automated-data-scraper-bot",
  "version": "0.2.0",
  "description": "Config-driven bot that watches retail, housing, and stock data sources and sends Telegram or Discord alerts when rules match.",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "app:build": "vite build && tsc -p tsconfig.json",
    "app:dev": "tsx src/server.ts",
    "app:start": "NODE_ENV=production node dist/src/server.js",
    "build": "npm run app:build",
    "bot:watch": "tsx watch src/index.ts watch",
    "dev": "tsx src/server.ts",
    "lint": "eslint .",
    "scrape:once": "tsx src/index.ts run",
    "scrape:watch": "tsx src/index.ts watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "data-scraper-bot": "./dist/index.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
