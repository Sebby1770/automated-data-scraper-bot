# Local bot settings
CONFIG_PATH=config.example.yml
STATE_DRIVER=file
STATE_FILE=data/seen-items.json
LOG_LEVEL=info

# Vercel Cron protection. Set this in Vercel and send Authorization: Bearer <secret>.
CRON_SECRET=change-me

# Optional visual dashboard protection. If set, the UI will ask for it before manual runs.
DASHBOARD_SECRET=

# Discord webhook notification
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram bot notification
TELEGRAM_BOT_TOKEN=123456:abc...
TELEGRAM_CHAT_ID=123456789

# Slack incoming webhook notification
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Generic webhook notification (POSTs alert JSON)
WEBHOOK_URL=https://your-service.example.com/alerts

# Optional persistent state for serverless/Vercel deployments.
# These match Upstash Redis REST env names commonly provisioned on Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
