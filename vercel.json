{
  "buildCommand": "npm run app:build",
  "outputDirectory": "dist/client",
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/cron/scrape.ts": {
      "maxDuration": 60
    },
    "api/run.ts": {
      "maxDuration": 60
    }
  }
}
